# ========================
# Supabase Configuration
# ========================

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"

# Supabase Anon Key (Public Key)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase Service Role Key (Private Key)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ========================
# AI API Key
# ========================

# Gemini API Key - Main API key used for all AI operations with gemini-2.5-flash-lite model
GEMINI_API_KEY="your-gemini-api-key"

# ========================
# Redis Configuration
# ========================

# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"

# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# ========================
# Application Configuration
# ========================

# Site URL (Development)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Share Service URL (for resume sharing links)
# Development: http://localhost:3001
# Production: https://share.resumy.com
NEXT_PUBLIC_SHARE_URL="http://localhost:3001"

# Site URL (Production)
# NEXT_PUBLIC_SITE_URL="https://your-production-url.com"

# Migration Route Security (recommended for production)
# Keep disabled unless you need the migration endpoint
ENABLE_MIGRATION_ROUTE="false"
MIGRATION_ROUTE_TOKEN="set-a-long-random-secret"

# ========================
# Push Notifications (Optional)
# ========================

# VAPID Keys for Web Push Notifications
# Generate using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# ========================
# Analytics Configuration
# ========================

# Google Analytics Tracking ID
NEXT_PUBLIC_GA_TRACKING_ID="G-TXWV913LE4"
 