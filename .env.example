# ========================
# Supabase Configuration
# ========================

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"

# Supabase Anon Key (Public Key)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase Service Role Key (Private Key)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ========================
# AI API Key
# ========================

# Gemini API Key - Main API key used for all AI operations with gemini-2.5-flash-lite model
GEMINI_API_KEY="your-gemini-api-key"

# API for Analyze - Primary key for resume analysis, falls back to GEMINI_API_KEY when limit exceeded
GEMINI_ANALYZE_API_KEY="your-gemini-analyze-api-key"

# ========================
# Redis Configuration
# ========================

# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"

# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# ========================
# Application Configuration
# ========================

# Site URL (Development)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Site URL (Production)
# NEXT_PUBLIC_SITE_URL="https://your-production-url.com"
 